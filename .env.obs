# =============================================================================
# Local Grafana + Tempo defaults — copy onto the end of your .env when you
# bring up the `obs` profile (docker compose --profile obs up -d).
# Then restart the API container so the new OTEL endpoint takes effect.
# =============================================================================

# Trace export — Tempo's OTLP/HTTP receiver is on 4318 inside the obs network.
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
OTEL_SERVICE_NAME=mini-ai-assistant