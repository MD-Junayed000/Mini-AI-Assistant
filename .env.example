# Mini AI Assistant — environment variables (copy to .env)

OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1
OLLAMA_CLOUD_API_KEY=your-ollama-cloud-key
OLLAMA_PRIMARY_MODEL=gpt-oss:20b
OLLAMA_FALLBACK_MODEL=gpt-oss:120b
OLLAMA_TIMEOUT_SECONDS=30

HF_INFERENCE_BASE_URL=https://router.huggingface.co/v1
HF_INFERENCE_API_KEY=your-hf-token
HF_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Figure captioning for PDF ingestion. Set OLLAMA_VISION_MODEL="" to disable.
VISION_PROVIDER=ollama
OLLAMA_VISION_MODEL=gemma4:31b-cloud
HF_VISION_MODEL=google/gemma-3-27b-it

HF_HUB_DISABLE_XET=1

CHROMA_USE_CLOUD=true
CHROMA_HOST=api.trychroma.com
CHROMA_API_KEY=your-chroma-api-key
CHROMA_TENANT=your-tenant-id
CHROMA_DATABASE=mini_ai
CHROMA_COLLECTION=mini_ai_kb
CHROMA_PERSIST_DIR=./.chroma
BM25_CACHE_PATH=./.chroma/bm25.pkl

MONGODB_URI=mongodb+srv://user:pass@cluster0.mongodb.net/?appName=mini-a
MONGODB_DB=mini_ai
MONGODB_COLLECTION=messages

RATE_LIMIT_PER_MIN=30
HEALTH_CACHE_TTL_SECONDS=10
MAX_CONTEXT_CHARS=8000
CONFIDENCE_GATE_THRESHOLD=0.62
CORS_ORIGINS=*
RERANK_DISABLED=false

LOG_DIR=./logs
LOG_LEVEL=INFO
LOG_MAX_BYTES=52428800
LOG_BACKUP_COUNT=5

# OpenTelemetry. Empty endpoint = no-op. Local: docker compose --profile obs up -d,
# then OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=mini-ai-assistant
