# =============================================================================
# Mini AI Assistant — environment variables (copy to .env, do NOT commit real)
# =============================================================================

# --- LLM (Ollama Cloud, OpenAI-compatible) ---------------------------------
OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1
OLLAMA_CLOUD_API_KEY=your-ollama-cloud-key
OLLAMA_PRIMARY_MODEL=qwen3.5:122b-cloud
OLLAMA_FALLBACK_MODEL=gpt-oss:120b-cloud
OLLAMA_TIMEOUT_SECONDS=30

# --- Embeddings (Hugging Face Inference Providers, free tier) ---------------
HF_INFERENCE_BASE_URL=https://router.huggingface.co/v1
HF_INFERENCE_API_KEY=your-hf-token
HF_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
HF_RERANK_MODEL=BAAI/bge-reranker-base
HF_VISION_MODEL=ibm-granite/granite-docling-258M

# --- Vector store -----------------------------------------------------------
CHROMA_PERSIST_DIR=./.chroma
CHROMA_COLLECTION=mini_ai_kb
BM25_CACHE_PATH=./.chroma/bm25.pkl

# --- Memory (MongoDB Atlas free M0) -----------------------------------------
MONGODB_URI=mongodb+srv://user:pass@cluster0.mongodb.net/?appName=mini-ai
MONGODB_DB=mini_ai
MONGODB_COLLECTION=messages

# --- Runtime knobs ----------------------------------------------------------
RATE_LIMIT_PER_MIN=30
HEALTH_CACHE_TTL_SECONDS=10
MAX_CONTEXT_CHARS=8000
CONFIDENCE_GATE_THRESHOLD=0.62  # calibrated against tests/eval_set.jsonl

# --- Logging ----------------------------------------------------------------
LOG_DIR=./logs
LOG_LEVEL=INFO
LOG_MAX_BYTES=52428800      # 50 MB
LOG_BACKUP_COUNT=5

# --- OpenTelemetry ----------------------------------------------------------
# When OTEL_EXPORTER_OTLP_ENDPOINT is empty, tracing is a NO-OP (zero cost).
#
# To enable LOCAL tracing via the bundled Grafana + Tempo stack, run:
#
#   docker compose --profile obs up -d
#   cat .env.obs >> .env       # adds OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
#   docker compose restart api
#
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=mini-ai-assistant
